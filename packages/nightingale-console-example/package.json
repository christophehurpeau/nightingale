{
  "name": "nightingale-console-example",
  "version": "18.2.0",
  "private": true,
  "homepage": "https://github.com/christophehurpeau/nightingale",
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/nightingale.git",
    "directory": "packages/nightingale-console-example"
  },
  "type": "module",
  "main": "./build/index-node.mjs",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "node": {
        "import": "./build/index-node.mjs"
      }
    },
    "./children": {
      "types": "./src/children.ts",
      "node": {
        "import": "./build/children-node.mjs"
      }
    },
    "./sentry": {
      "types": "./src/sentry.ts",
      "node": {
        "import": "./build/sentry-node.mjs"
      }
    }
  },
  "scripts": {
    "build": "yarn run clean:build && rollup --config rollup.config.mjs",
    "clean": "yarn run clean:build",
    "clean:build": "pob-esbuild-clean-out build",
    "lint": "yarn run lint:eslint",
    "lint:eslint": "yarn '../..' run eslint --quiet 'packages/nightingale-console-example'",
    "start": "yarn run clean:build && rollup --config rollup.config.mjs --watch",
    "tsc": "tsc",
    "watch": "pob-watch"
  },
  "dependencies": {
    "@sentry/core": "10.63.0",
    "@sentry/node": "10.63.0",
    "nightingale": "18.2.0",
    "nightingale-console": "18.2.0",
    "nightingale-sentry": "18.2.0"
  },
  "devDependencies": {
    "@pob/rollup-esbuild": "9.1.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "pob": {
    "bundler": "rollup-esbuild",
    "entries": [
      "index",
      "children",
      "sentry"
    ],
    "envs": [
      {
        "target": "node",
        "version": "24",
        "omitVersionInFileName": true
      }
    ],
    "typescript": true
  }
}
