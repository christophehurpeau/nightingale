{
  "name": "nightingale-example",
  "version": "18.1.0",
  "private": true,
  "homepage": "https://github.com/christophehurpeau/nightingale",
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/nightingale.git",
    "directory": "packages/nightingale-example"
  },
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./configure": {
      "types": "./src/configure.ts",
      "node": {
        "import": "./build/configure-node.mjs"
      }
    },
    "./cli": {
      "types": "./src/cli.ts",
      "node": {
        "import": "./build/cli-node.mjs"
      }
    },
    "./console": {
      "types": "./src/console.ts",
      "node": {
        "import": "./build/console-node.mjs"
      }
    },
    "./debug": {
      "types": "./src/debug.ts",
      "node": {
        "import": "./build/debug-node.mjs"
      }
    },
    "./errors": {
      "types": "./src/errors.ts",
      "node": {
        "import": "./build/errors-node.mjs"
      }
    },
    "./jsonConsole": {
      "types": "./src/jsonConsole.ts",
      "node": {
        "import": "./build/jsonConsole-node.mjs"
      }
    },
    "./slack": {
      "types": "./src/slack.ts",
      "node": {
        "import": "./build/slack-node.mjs"
      }
    }
  },
  "scripts": {
    "build": "yarn run clean:build && rollup --config rollup.config.mjs",
    "clean": "yarn run clean:build",
    "clean:build": "pob-esbuild-clean-out build",
    "lint": "yarn run lint:eslint",
    "lint:eslint": "yarn '../..' run eslint --quiet 'packages/nightingale-example'",
    "start": "yarn run clean:build && rollup --config rollup.config.mjs --watch",
    "tsc": "tsc",
    "watch": "pob-watch"
  },
  "dependencies": {
    "nightingale": "18.1.0",
    "nightingale-slack": "18.1.0",
    "nightingale-types": "18.0.0"
  },
  "devDependencies": {
    "@pob/rollup-esbuild": "9.1.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "pob": {
    "bundler": "rollup-esbuild",
    "entries": [
      "configure",
      "cli",
      "console",
      "debug",
      "errors",
      "jsonConsole",
      "slack"
    ],
    "envs": [
      {
        "target": "node",
        "version": "24",
        "omitVersionInFileName": true
      }
    ],
    "typescript": true
  }
}
